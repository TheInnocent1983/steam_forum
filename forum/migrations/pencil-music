{% extends 'forum/base.html' %}

{% block title %}{{ game.name }}{% endblock %}

{% block content %}
<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-dark text-light px-3 py-2 rounded">
            <li class="breadcrumb-item">
                <a href="{% url 'game_list' %}" class="text-decoration-none text-info">Все игры</a>
            </li>
            <li class="breadcrumb-item active text-light" aria-current="page">{{ game.name }}</li>
        </ol>
    </nav>

    <!-- Header with create button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-light">{{ game.name }}</h1>
        <a href="{% url 'create_topic' game.pk %}" class="btn btn-success">Создать тему</a>
    </div>

    <!-- Topics list -->
    <div class="list-group shadow-sm">
        <div class="list-group-item bg-dark text-light fw-bold">Темы обсуждения</div>
        {% for topic in game.topics.all %}
            <a href="{% url 'topic_detail' topic.pk %}" 
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-dark text-light border-secondary">
                <div>
                    <span class="h6 mb-0">{{ topic.title }}</span>
                    <div class="small text-muted">Автор: {{ topic.author.username }}</div>
                </div>
                <span class="badge bg-secondary rounded-pill">{{ topic.comments.count }} ответов</span>
            </a>
        {% empty %}
            <div class="list-group-item text-center text-muted bg-dark border-secondary">Здесь пока нет тем. Станьте первым!</div>
        {% endfor %}
    </div>
</div>
{% endblock %}
